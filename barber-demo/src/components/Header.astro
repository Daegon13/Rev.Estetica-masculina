---
import barber from "@data/barber.json";
import { buildWhatsAppLink } from "@lib/whatsapp";

type Props = {
  currentPath?: string;
};

const { currentPath = "/" } = Astro.props as Props;

const wa = buildWhatsAppLink(
  barber.whatsapp,
  `Hola, quiero reservar una experiencia en ${barber.nombre}. ¿Qué disponibilidad tienen?`
);

const mark = barber?.branding?.logoMark;
const wordmark = barber?.branding?.logoWordmark;
const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios" },
  { href: "/galeria", label: "Galería" },
  { href: "/ubicacion", label: "Ubicación" },
  { href: "/admin-demo", label: "Admin demo" }
];
---

<header class="fixed left-0 right-0 top-0 z-50 border-b border-stone-200/10 bg-[#0c0e10]/78 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="group flex items-center gap-3 rounded-xl px-2 py-1 focus:outline-none focus:ring-2 focus:ring-[#c8a27c]/40">
      {wordmark ? (
        <img
          src={wordmark}
          alt={`${barber.nombre} logo`}
          class="h-20 w-auto opacity-95 transition group-hover:opacity-100"
          loading="eager"
          decoding="async"
        />
      ) : mark ? (
        <img
          src={mark}
          alt={`${barber.nombre} logo`}
          class="h-20 w-20 opacity-95 transition group-hover:opacity-100"
          loading="eager"
          decoding="async"
        />
      ) : (
        <div>
          <span class="block text-sm font-semibold tracking-[0.18em] text-stone-100">REVOLUCIÓN</span>
          <span class="block text-[11px] uppercase tracking-[0.34em] text-stone-400">Estética masculina</span>
        </div>
      )}
    </a>

    <nav class="hidden items-center gap-6 text-sm text-zinc-300 md:flex">
      {navItems.map((item) => (
        <a class={`transition hover:text-stone-100 ${currentPath === item.href ? "text-stone-100" : ""}`} href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href="/turnos" class="btn-secondary hidden min-h-0 rounded-xl px-4 py-2 sm:inline-flex">Ver horarios</a>
      <a href={wa} target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-xl border border-[#c8a27c]/35 bg-[#c8a27c]/14 px-4 py-2 text-sm font-semibold text-stone-100 transition hover:bg-[#c8a27c]/22">
        Reservar
      </a>
    </div>
  </div>

  <nav class="border-t border-white/5 bg-black/10 px-4 py-2 md:hidden">
    <div class="mx-auto flex max-w-6xl gap-2 overflow-x-auto pb-1 text-sm text-zinc-300 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`whitespace-nowrap rounded-full border px-3 py-2 transition ${currentPath === item.href ? "border-[#c8a27c]/35 bg-[#c8a27c]/14 text-stone-100" : "border-white/10 bg-white/5 hover:bg-white/10"}`}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>
