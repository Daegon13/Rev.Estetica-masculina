---
const { image = "/og/og-cover.png" } = Astro.props;
---

<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
  <div
    class="absolute inset-0 scale-105 bg-cover bg-center opacity-[0.16] blur-[2px]"
    style={`background-image: url('${image}');`}
  ></div>

  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(200,162,124,0.10),transparent_35%),linear-gradient(180deg,#0b0d0f_0%,#121518_55%,#090b0d_100%)]"></div>

  <div
    class="absolute inset-0"
    style="background-image: radial-gradient(65% 55% at 50% 15%, rgba(255,255,255,0.02) 0%, rgba(0,0,0,0.58) 62%, rgba(0,0,0,0.9) 100%);"
  ></div>
</div>
