---
import barber from "@data/barber.json";

const mark = barber?.branding?.logoMark;
const wordmark = barber?.branding?.logoWordmark;
---

<footer class="mt-16 border-t border-stone-200/10 bg-black/30">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        {wordmark ? (
          <img src={wordmark} alt={`${barber.nombre} logo`} class="h-20 auto" loading="lazy" decoding="async" />
        ) : mark ? (
          <img src={mark} alt={`${barber.nombre} logo`} class="h-12 w-12" loading="lazy" decoding="async" />
        ) : (
          <div class="rounded-2xl border border-[#c8a27c]/25 bg-[#c8a27c]/10 px-4 py-3 text-xs uppercase tracking-[0.3em] text-stone-200">
            REM
          </div>
        )}

        <div>
          <div class="text-sm font-semibold text-zinc-50">{barber.nombre}</div>
          <div class="mt-1 text-xs text-zinc-400">{barber.direccion} · {barber.ciudad}</div>
        </div>
      </div>

      <div class="text-xs uppercase tracking-[0.24em] text-stone-400">
        Reserva online · Atención profesional
      </div>
    </div>

    <div class="mt-6 text-xs text-zinc-500">
      Centro de estética masculina con atención personalizada, reserva online y seguimiento por WhatsApp para una experiencia prolija de punta a punta.
    </div>
  </div>
</footer>
