---
import { demoMessageTemplates, demoTemplateVariables } from "@data/messageTemplates";

const templates = demoMessageTemplates;
const variables = demoTemplateVariables;
const initialTemplate = templates[0];
---

<section class="rounded-3xl border border-white/10 bg-white/[0.045] p-5 shadow-soft sm:p-6" data-message-templates-root>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 rounded-full border border-[#c8a27c]/20 bg-[#c8a27c]/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#e8cfb6]">
        Plantillas demo
      </div>
      <h2 class="mt-3 text-xl font-semibold text-zinc-50 sm:text-2xl">Mensajes automáticos editables, listos para conectar con WhatsApp API o email.</h2>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-400">
        El módulo está pensado como capa de contenido reutilizable: cada plantilla define trigger, canal, variables y texto editable sin acoplarse al proveedor de envío.
      </p>
    </div>

    <div class="grid min-w-[220px] gap-3 rounded-2xl border border-white/10 bg-black/20 p-4 text-sm">
      <div class="flex items-center justify-between gap-4">
        <span class="text-zinc-400">Plantillas activas</span>
        <strong class="text-zinc-50">4 / 5</strong>
      </div>
      <div class="flex items-center justify-between gap-4">
        <span class="text-zinc-400">Variables soportadas</span>
        <strong class="text-zinc-50">4</strong>
      </div>
      <div class="flex items-center justify-between gap-4">
        <span class="text-zinc-400">Canales futuros</span>
        <strong class="text-zinc-50">WA · Email</strong>
      </div>
    </div>
  </div>

  <div class="mt-6 grid gap-6 xl:grid-cols-[1.15fr_.85fr]">
    <div class="space-y-4">
      {templates.map((template) => (
        <article class="rounded-[1.6rem] border border-white/10 bg-gradient-to-br from-white/[0.06] via-white/[0.03] to-black/20 p-4">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-4">
              <div class="flex flex-wrap items-start gap-3">
                <button
                  type="button"
                  class={`inline-flex h-7 w-12 items-center rounded-full border transition ${template.active ? 'justify-end border-emerald-300/30 bg-emerald-400/20' : 'justify-start border-white/10 bg-white/10'} p-1`}
                  aria-pressed={template.active ? 'true' : 'false'}
                  aria-label={`Estado de ${template.name}`}
                >
                  <span class={`h-5 w-5 rounded-full ${template.active ? 'bg-emerald-200' : 'bg-zinc-500'}`}></span>
                </button>

                <div>
                  <div class="flex flex-wrap items-center gap-2">
                    <h3 class="text-base font-semibold text-zinc-50">{template.name}</h3>
                    <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-300">{template.category}</span>
                    <span class={`rounded-full border px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] ${template.active ? 'border-emerald-300/20 bg-emerald-400/10 text-emerald-200' : 'border-white/10 bg-white/5 text-zinc-400'}`}>
                      {template.active ? 'Activa' : 'Inactiva'}
                    </span>
                  </div>
                  <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-400">{template.description}</p>
                </div>
              </div>

              <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                <div class="rounded-2xl border border-white/10 bg-black/20 p-3">
                  <div class="text-[11px] uppercase tracking-[0.18em] text-zinc-500">Trigger</div>
                  <div class="mt-2 text-sm font-medium text-zinc-100">{template.trigger}</div>
                </div>
                <div class="rounded-2xl border border-white/10 bg-black/20 p-3">
                  <div class="text-[11px] uppercase tracking-[0.18em] text-zinc-500">Canal</div>
                  <div class="mt-2 text-sm font-medium text-zinc-100">{template.channel}</div>
                </div>
                <div class="rounded-2xl border border-white/10 bg-black/20 p-3">
                  <div class="text-[11px] uppercase tracking-[0.18em] text-zinc-500">Audiencia</div>
                  <div class="mt-2 text-sm font-medium text-zinc-100">{template.audience}</div>
                </div>
                <div class="rounded-2xl border border-white/10 bg-black/20 p-3">
                  <div class="text-[11px] uppercase tracking-[0.18em] text-zinc-500">Impacto</div>
                  <div class="mt-2 text-sm font-medium text-zinc-100">{template.performance}</div>
                </div>
              </div>
            </div>

            <div class="lg:w-[290px] lg:min-w-[290px]">
              <div class="rounded-[1.35rem] border border-[#c8a27c]/20 bg-[#c8a27c]/8 p-4">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <div class="text-[11px] uppercase tracking-[0.18em] text-[#d7b897]">Preview dinámica</div>
                    <div class="mt-1 text-sm text-zinc-400">Variables: {template.variables.map((variable) => `{${variable}}`).join(" · ")}</div>
                  </div>
                  <button
                    type="button"
                    class="inline-flex items-center justify-center rounded-full border border-[#c8a27c]/30 bg-black/20 px-4 py-2 text-xs font-semibold text-[#f0dcc7] transition hover:border-[#c8a27c]/45 hover:bg-[#c8a27c]/10"
                    data-template-open
                    data-template-id={template.id}
                  >
                    Editar demo
                  </button>
                </div>
                <p class="mt-4 rounded-2xl border border-white/10 bg-black/25 p-4 text-sm leading-6 text-zinc-200">
                  {template.body}
                </p>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <aside class="space-y-5 rounded-[1.75rem] border border-[#c8a27c]/20 bg-gradient-to-br from-[#c8a27c]/14 via-white/[0.03] to-white/[0.02] p-5 shadow-soft">
      <div>
        <div class="text-sm text-zinc-300">Vista previa comercial</div>
        <div class="mt-2 text-2xl font-semibold text-zinc-50" data-preview-name>{initialTemplate.name}</div>
        <p class="mt-2 text-sm leading-6 text-zinc-300" data-preview-description>{initialTemplate.description}</p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
        <div class="flex items-center justify-between gap-3 text-xs uppercase tracking-[0.18em] text-zinc-500">
          <span>Asunto</span>
          <span data-preview-channel>{initialTemplate.channel}</span>
        </div>
        <div class="mt-2 text-sm font-medium text-zinc-100" data-preview-subject>{initialTemplate.subject}</div>
      </div>

      <div class="rounded-[1.5rem] border border-white/10 bg-black/25 p-4">
        <div class="flex items-center justify-between gap-3">
          <div class="text-[11px] uppercase tracking-[0.18em] text-[#d7b897]">Mensaje renderizado</div>
          <button type="button" class="text-xs font-semibold text-[#f0dcc7] transition hover:text-white" data-template-open data-template-id={initialTemplate.id}>Editar</button>
        </div>
        <p class="mt-4 whitespace-pre-line text-sm leading-6 text-zinc-200" data-preview-body></p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-black/20 p-4">
        <div class="text-[11px] uppercase tracking-[0.18em] text-zinc-500">Variables simuladas</div>
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
          {Object.entries(variables).map(([key, value]) => (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-3">
              <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">{`{${key}}`}</div>
              <div class="mt-2 text-sm text-zinc-100">{value}</div>
            </div>
          ))}
        </div>
      </div>
    </aside>
  </div>

  <dialog class="backdrop:bg-black/70 w-full max-w-2xl rounded-[1.8rem] border border-white/10 bg-[#111417] p-0 text-zinc-100 shadow-2xl" data-template-modal>
    <form method="dialog" class="border-b border-white/10 px-5 py-4 sm:px-6">
      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="text-[11px] uppercase tracking-[0.18em] text-[#d7b897]">Editor demo</div>
          <h3 class="mt-2 text-xl font-semibold text-zinc-50" data-modal-title></h3>
          <p class="mt-1 text-sm text-zinc-400" data-modal-trigger></p>
        </div>
        <button type="submit" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-zinc-200">Cerrar</button>
      </div>
    </form>

    <div class="grid gap-5 p-5 sm:p-6">
      <label class="grid gap-2">
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Asunto demo</span>
        <input class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-100" type="text" data-editor-subject />
      </label>

      <label class="grid gap-2">
        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Texto del mensaje</span>
        <textarea class="min-h-[180px] rounded-3xl border border-white/10 bg-black/20 px-4 py-4 text-sm leading-6 text-zinc-100" data-editor-body></textarea>
      </label>

      <div class="rounded-2xl border border-[#c8a27c]/20 bg-[#c8a27c]/8 p-4">
        <div class="text-[11px] uppercase tracking-[0.18em] text-[#d7b897]">Resultado con variables demo</div>
        <p class="mt-3 whitespace-pre-line text-sm leading-6 text-zinc-200" data-editor-preview></p>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="text-xs text-zinc-500">Variables disponibles: {Object.keys(variables).map((key) => `{${key}}`).join(" · ")}</div>
        <div class="flex flex-wrap gap-2">
          <button type="button" class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold text-zinc-200" data-editor-reset>Restablecer texto</button>
          <button type="button" class="rounded-full border border-[#c8a27c]/30 bg-[#c8a27c]/10 px-4 py-2 text-xs font-semibold text-[#f0dcc7]" data-editor-apply>Aplicar a la vista previa</button>
        </div>
      </div>
    </div>
  </dialog>
</section>

<script define:vars={{ templates, variables, initialTemplateId: initialTemplate.id }}>
  const root = document.querySelector('[data-message-templates-root]');

  if (root) {
    const templateMap = new Map(templates.map((template) => [template.id, { ...template }]));
    const modal = root.querySelector('[data-template-modal]');
    const previewName = root.querySelector('[data-preview-name]');
    const previewDescription = root.querySelector('[data-preview-description]');
    const previewSubject = root.querySelector('[data-preview-subject]');
    const previewChannel = root.querySelector('[data-preview-channel]');
    const previewBody = root.querySelector('[data-preview-body]');
    const modalTitle = root.querySelector('[data-modal-title]');
    const modalTrigger = root.querySelector('[data-modal-trigger]');
    const subjectInput = root.querySelector('[data-editor-subject]');
    const bodyInput = root.querySelector('[data-editor-body]');
    const editorPreview = root.querySelector('[data-editor-preview]');
    const resetButton = root.querySelector('[data-editor-reset]');
    const applyButton = root.querySelector('[data-editor-apply]');

    let selectedId = initialTemplateId;

    const renderWithVariables = (text) =>
      text.replace(/\{(nombre|fecha|hora|descuento)\}/g, (_, key) => variables[key] ?? `{${key}}`);

    const syncPreviewPanel = () => {
      const current = templateMap.get(selectedId);
      if (!current) return;

      previewName.textContent = current.name;
      previewDescription.textContent = current.description;
      previewSubject.textContent = current.subject;
      previewChannel.textContent = current.channel;
      previewBody.textContent = renderWithVariables(current.body);

      const editButton = root.querySelector('[data-preview-name]')?.closest('aside')?.querySelector('[data-template-open]');
      if (editButton) editButton.dataset.templateId = current.id;
    };

    const syncModal = () => {
      const current = templateMap.get(selectedId);
      if (!current) return;

      modalTitle.textContent = current.name;
      modalTrigger.textContent = `${current.trigger} · ${current.channel}`;
      subjectInput.value = current.subject;
      bodyInput.value = current.body;
      editorPreview.textContent = renderWithVariables(current.body);
    };

    root.querySelectorAll('[data-template-open]').forEach((button) => {
      button.addEventListener('click', () => {
        selectedId = button.dataset.templateId || initialTemplateId;
        syncModal();
        if (typeof modal.showModal === 'function') modal.showModal();
      });
    });

    bodyInput?.addEventListener('input', () => {
      editorPreview.textContent = renderWithVariables(bodyInput.value);
    });

    subjectInput?.addEventListener('input', () => {
      const current = templateMap.get(selectedId);
      if (!current) return;
      current.subject = subjectInput.value;
    });

    resetButton?.addEventListener('click', () => {
      const original = templates.find((template) => template.id === selectedId);
      if (!original) return;
      templateMap.set(selectedId, { ...original });
      syncModal();
      syncPreviewPanel();
    });

    applyButton?.addEventListener('click', () => {
      const current = templateMap.get(selectedId);
      if (!current) return;
      current.subject = subjectInput.value;
      current.body = bodyInput.value;
      syncPreviewPanel();
      modal.close();
    });

    syncPreviewPanel();
  }
</script>
