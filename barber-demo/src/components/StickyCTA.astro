---
import { buildWhatsAppLink } from "@lib/whatsapp";
const { brand, whatsapp } = Astro.props;

const href = buildWhatsAppLink(
  whatsapp,
  `Hola, quiero reservar una experiencia en ${brand}. ¿Qué disponibilidad tienen?`
);
---
<div class="fixed inset-x-0 bottom-0 z-50 md:hidden">
  <div class="mx-auto max-w-6xl px-4 pb-4">
    <div class="flex gap-2 rounded-2xl border border-stone-200/10 bg-[#111315]/90 p-2 shadow-soft backdrop-blur">
      <a
        href="/servicios"
        class="flex-1 rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-center text-sm font-semibold text-zinc-100 transition hover:bg-white/10"
      >
        Servicios
      </a>
      <a
        href={href}
        target="_blank"
        rel="noreferrer"
        class="flex-[1.25] rounded-xl border border-[#c8a27c]/35 bg-[#c8a27c]/14 px-4 py-3 text-center text-sm font-semibold text-stone-100 transition hover:bg-[#c8a27c]/22"
      >
        Reservar turno
      </a>
    </div>
  </div>
</div>
