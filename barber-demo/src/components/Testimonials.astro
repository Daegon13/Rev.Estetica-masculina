---
type Testimonio = {
  nombre: string;
  texto: string;
  rating: number;
};

const { items } = Astro.props as { items: Testimonio[] };

const stars = (n: number) => "★★★★★☆☆☆☆☆".slice(5 - n, 10 - n);
---

<div class="grid gap-4 md:grid-cols-3">
  {items.map((t: Testimonio, index) => (
    <figure class={`rounded-[1.75rem] border p-5 shadow-soft ${index === 0 ? 'border-[#c8a27c]/25 bg-[linear-gradient(180deg,rgba(200,162,124,0.15),rgba(255,255,255,0.04))]' : 'border-white/10 bg-white/5'}`}>
      <div class="flex items-center justify-between gap-3">
        <div class="text-sm text-[#e7c7a3]">{stars(t.rating)}</div>
        <span class="rounded-full border border-white/10 bg-black/20 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-300">Cliente frecuente</span>
      </div>
      <blockquote class="mt-4 text-sm leading-7 text-zinc-200">
        “{t.texto}”
      </blockquote>
      <figcaption class="mt-5 text-sm font-medium text-zinc-400">— {t.nombre}</figcaption>
    </figure>
  ))}
</div>
