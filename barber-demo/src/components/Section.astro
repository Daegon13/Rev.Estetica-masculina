---
const { title, subtitle, ...attrs } = Astro.props;
---
<section class="py-10" {...attrs}>
  <div class="mb-6 flex flex-col gap-2">
    <h2 class="text-xl font-semibold tracking-tight text-zinc-50 sm:text-2xl">{title}</h2>
    {subtitle && <p class="max-w-2xl text-sm text-zinc-400">{subtitle}</p>}
  </div>
  <slot />
</section>
