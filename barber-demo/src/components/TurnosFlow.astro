---
import barber from "@data/barber.json";
import { formatUYU } from "@lib/whatsapp";
import scriptUrl from "@scripts/turnos.ts?url";

const servicios = barber.servicios;
const brand = barber.nombre;
const whatsapp = barber.whatsapp;
const url = new URL(Astro.request.url);
const pre = url.searchParams.get("servicio") ?? "";
---
<section class="rounded-2xl border border-stone-200/10 bg-white/5 p-5 shadow-soft md:p-6">
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-zinc-50">Reserva tu turno</h1>
      <p class="mt-2 max-w-2xl text-sm text-zinc-400">
        Elegí el servicio ideal para tu imagen, seleccioná día y hora y confirmá la reserva por WhatsApp con el mensaje listo.
      </p>
    </div>

    <div class="rounded-xl border border-stone-200/10 bg-black/20 px-4 py-3">
      <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Reserva online</div>
      <div class="text-sm text-zinc-200">Objetivo: <span class="font-semibold text-zinc-50">simple, rápida y profesional</span></div>
    </div>
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-2">
    <div>
      <div class="text-sm font-semibold text-zinc-200">1) Elegí un servicio</div>

      <div class="mt-3 grid gap-3">
        {servicios.map((s) => (
          <button
            type="button"
            class="service-btn rounded-2xl border border-white/10 bg-white/5 p-4 text-left transition hover:bg-white/10"
            data-service={s.nombre}
          >
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="flex items-center gap-2">
                  <div class="font-semibold text-zinc-50">{s.nombre}</div>
                  {s.popular && (
                    <span class="rounded-full border border-[#c8a27c]/35 bg-[#c8a27c]/12 px-2 py-0.5 text-[11px] text-stone-200">
                      Destacado
                    </span>
                  )}
                </div>
                <div class="mt-1 text-sm text-zinc-400">{s.descripcion}</div>
              </div>
              <div class="text-right">
                <div class="text-sm text-zinc-400">{s.duracion} min</div>
                <div class="text-base font-semibold text-zinc-50">{formatUYU(s.precio)}</div>
              </div>
            </div>
          </button>
        ))}
      </div>
    </div>

    <div>
      <div class="text-sm font-semibold text-zinc-200">2) Elegí día y hora</div>

      <div class="mt-3 rounded-2xl border border-white/10 bg-black/20 p-5">
        <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Resumen</div>

        <div class="mt-3 grid gap-2">
          <div class="flex items-center justify-between">
            <div class="text-sm text-zinc-400">Servicio</div>
            <div id="selectedService" class="text-sm font-semibold text-zinc-50">—</div>
          </div>
          <div class="flex items-center justify-between">
            <div class="text-sm text-zinc-400">Día</div>
            <div id="selectedDay" class="text-sm font-semibold text-zinc-50">—</div>
          </div>
          <div class="flex items-center justify-between">
            <div class="text-sm text-zinc-400">Hora</div>
            <div id="selectedTime" class="text-sm font-semibold text-zinc-50">—</div>
          </div>
        </div>

        <div class="mt-4 flex flex-col gap-2 sm:flex-row">
          <button
            type="button"
            id="openSlots"
            class="rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-zinc-100 transition hover:bg-white/10"
          >
            Ver horarios
          </button>

          <a
            id="waCta"
            href="#"
            target="_blank"
            rel="noreferrer"
            class="pointer-events-none rounded-xl border border-[#c8a27c]/35 bg-[#c8a27c]/14 px-4 py-3 text-center text-sm font-semibold text-stone-100 opacity-60 transition hover:bg-[#c8a27c]/22"
          >
            Confirmar por WhatsApp
          </a>
        </div>

        <p class="mt-3 text-xs text-zinc-500">
          Demo de agenda: el calendario es simulado y el mensaje final queda listo para enviar.
        </p>
      </div>

      <div class="mt-4 rounded-2xl border border-white/10 bg-white/5 p-5">
        <div class="text-sm font-semibold text-zinc-200">Lo que podés esperar</div>
        <ul class="mt-3 grid gap-2 text-sm text-zinc-300">
          <li class="flex gap-2"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#c8a27c]"></span> Atención enfocada en imagen personal y prolijidad.</li>
          <li class="flex gap-2"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#c8a27c]"></span> Servicios claros, duración definida y experiencia profesional.</li>
          <li class="flex gap-2"><span class="mt-2 h-1.5 w-1.5 rounded-full bg-[#c8a27c]"></span> Reserva ágil para ordenar tu semana sin fricción.</li>
        </ul>
      </div>
    </div>
  </div>

  <dialog id="slotsDialog" class="w-[min(720px,92vw)] rounded-2xl border border-white/10 bg-[#111315] text-zinc-100 backdrop:bg-black/60">
    <div class="p-5 sm:p-6">
      <div class="flex items-start justify-between gap-4">
        <div>
          <div class="text-lg font-semibold">Horarios disponibles</div>
          <div class="text-sm text-zinc-400">Elegí un día y una hora para completar la reserva por WhatsApp.</div>
        </div>
        <button id="closeSlots" class="rounded-xl border border-white/10 bg-white/5 px-3 py-2 text-sm transition hover:bg-white/10">
          Cerrar
        </button>
      </div>

      <div class="mt-5 grid gap-4 md:grid-cols-2">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <div class="text-sm font-semibold text-zinc-200">Días</div>
          <div id="daysList" class="mt-3 grid grid-cols-2 gap-2"></div>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
          <div class="text-sm font-semibold text-zinc-200">Horas</div>
          <div class="mt-1 text-xs text-zinc-500">Slots simulados cada 30 min</div>
          <div id="timesList" class="mt-3 grid grid-cols-3 gap-2"></div>
        </div>
      </div>

      <div class="mt-5 rounded-2xl border border-white/10 bg-black/20 p-4">
        <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Mensaje de reserva</div>
        <div id="previewMsg" class="mt-2 text-sm leading-relaxed text-zinc-200">Seleccioná servicio, día y hora.</div>
      </div>
    </div>
  </dialog>

  <div
    id="turnosConfig"
    data-brand={brand}
    data-whatsapp={whatsapp}
    data-services={JSON.stringify(servicios)}
    data-preselected={pre}
    class="hidden"
  ></div>

  <script type="module" src={scriptUrl}></script>
</section>
