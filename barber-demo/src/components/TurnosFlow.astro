---
import barber from "@data/barber.json";
import { bookingDateOffsets, bookingProfessionals, bookingTimeWindows } from "@data/booking";
import { demoServices } from "@data/services";
import scriptUrl from "@scripts/turnos.ts?url";

const servicios = demoServices;
const profesionales = bookingProfessionals;
const brand = barber.nombre;
const whatsapp = barber.whatsapp;
const url = new URL(Astro.request.url);
const pre = url.searchParams.get("servicio") ?? "";
---
<section class="overflow-hidden rounded-[32px] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03))] shadow-soft">
  <div class="border-b border-white/10 bg-black/20 px-5 py-6 md:px-8 md:py-7">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs uppercase tracking-[0.28em] text-[#c8a27c]">Booking experience demo</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white md:text-4xl">Reservá en 6 pasos con una experiencia premium.</h1>
        <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-300 md:text-base">
          Este flujo está pensado para vender el producto: guía visual, selección asistida, guardado local, validación básica y cierre listo para integrar luego con Supabase.
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-3 lg:min-w-[360px]">
        <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
          <div class="text-[11px] uppercase tracking-[0.24em] text-zinc-500">Modo</div>
          <div class="mt-1 text-sm font-medium text-zinc-100">Demo lista para ventas</div>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
          <div class="text-[11px] uppercase tracking-[0.24em] text-zinc-500">Estado</div>
          <div class="mt-1 text-sm font-medium text-zinc-100">Sin backend, con mocks limpios</div>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
          <div class="text-[11px] uppercase tracking-[0.24em] text-zinc-500">Salida</div>
          <div class="mt-1 text-sm font-medium text-zinc-100">Resumen + WhatsApp</div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-0 xl:grid-cols-[1.3fr_0.7fr]">
    <div class="px-5 py-6 md:px-8 md:py-8">
      <div class="rounded-[28px] border border-white/10 bg-black/20 p-4 md:p-5">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <div>
            <div class="text-xs uppercase tracking-[0.24em] text-zinc-500">Progreso de reserva</div>
            <div id="bookingProgressText" class="mt-2 text-sm font-medium text-zinc-100">Paso 1 de 6</div>
          </div>
          <div class="md:max-w-[280px] md:flex-1">
            <div class="h-2 overflow-hidden rounded-full bg-white/10">
              <div id="bookingProgressBar" class="h-full w-0 rounded-full bg-[linear-gradient(90deg,#c8a27c,#f1d0b0)] transition-all duration-300"></div>
            </div>
          </div>
        </div>

        <div id="bookingSelectionPills" class="mt-4 flex flex-wrap gap-2"></div>
      </div>

      <div id="bookingStepper" class="mt-5 grid gap-3 md:grid-cols-3 xl:grid-cols-6"></div>

      <div id="bookingError" class="mt-5 hidden rounded-2xl border border-rose-400/30 bg-rose-500/10 px-4 py-3 text-sm text-rose-100" aria-live="polite"></div>

      <div class="mt-6">
        <div id="bookingPanels" class="space-y-4"></div>
      </div>

      <div class="mt-6 flex flex-col gap-3 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between">
        <button
          id="bookingBack"
          type="button"
          class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-5 text-sm font-semibold text-zinc-100 transition hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-40"
        >
          Volver
        </button>

        <div class="flex flex-col gap-3 sm:flex-row">
          <button
            id="bookingReset"
            type="button"
            class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-white/10 bg-transparent px-5 text-sm font-semibold text-zinc-300 transition hover:bg-white/5"
          >
            Reiniciar demo
          </button>
          <button
            id="bookingNext"
            type="button"
            class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-[#c8a27c]/40 bg-[#c8a27c]/16 px-6 text-sm font-semibold text-white transition hover:bg-[#c8a27c]/24"
          >
            Continuar
          </button>
        </div>
      </div>
    </div>

    <aside class="border-t border-white/10 bg-black/25 px-5 py-6 md:px-8 md:py-8 xl:border-l xl:border-t-0">
      <div class="rounded-[28px] border border-white/10 bg-[radial-gradient(circle_at_top,rgba(200,162,124,0.2),transparent_55%),rgba(255,255,255,0.04)] p-5 xl:sticky xl:top-28">
        <p class="text-xs uppercase tracking-[0.24em] text-zinc-500">Resumen en vivo</p>
        <h2 class="mt-3 text-xl font-semibold text-white">Tu turno, ordenado como producto.</h2>
        <p class="mt-2 text-sm leading-6 text-zinc-400">
          Cada paso actualiza el resumen final para que el usuario entienda qué está reservando y llegue al cierre con confianza.
        </p>

        <div id="bookingSummary" class="mt-5 space-y-3"></div>

        <div class="mt-5 rounded-2xl border border-white/10 bg-black/20 p-4">
          <div class="flex items-center justify-between gap-3">
            <div>
              <div class="text-xs uppercase tracking-[0.24em] text-zinc-500">Integración futura</div>
              <div class="mt-1 text-sm font-medium text-zinc-100">Supabase-ready</div>
            </div>
            <span class="rounded-full border border-emerald-400/30 bg-emerald-500/10 px-3 py-1 text-xs text-emerald-200">Mock data</span>
          </div>
          <p class="mt-3 text-sm leading-6 text-zinc-400">
            Servicios, profesionales y horarios viven en estructuras fáciles de reemplazar por tablas, RPCs o edge functions más adelante.
          </p>
        </div>
      </div>
    </aside>
  </div>

  <div
    id="turnosConfig"
    data-brand={brand}
    data-whatsapp={whatsapp}
    data-services={JSON.stringify(servicios)}
    data-professionals={JSON.stringify(profesionales)}
    data-date-offsets={JSON.stringify(bookingDateOffsets)}
    data-time-windows={JSON.stringify(bookingTimeWindows)}
    data-preselected={pre}
    class="hidden"
  ></div>

  <script type="module" src={scriptUrl}></script>
</section>
