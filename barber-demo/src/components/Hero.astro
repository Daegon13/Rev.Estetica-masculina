---
import barber from "@data/barber.json";

const { nombre, ciudad, media } = barber;

type Props = {
  title?: string;
  subtitle?: string;
};

const {
  title = "Cuidado masculino integral con una estética premium y contemporánea.",
  subtitle = `Un estudio de imagen masculina en ${ciudad} para reservar online, optimizar tu presencia y vivir una experiencia profesional de principio a fin.`
} = Astro.props as Props;
---

<section class="relative overflow-hidden rounded-3xl border border-stone-300/10 bg-white/5 shadow-soft">
  <picture class="absolute inset-0 -z-10">
    <source media="(max-width: 768px)" srcset={media.heroMobile} />
    <img
      src={media.heroDesktop}
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </picture>

  <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-r from-[#0f1113]/92 via-[#171a1d]/78 to-[#0f1113]/70"></div>

  <div
    aria-hidden="true"
    class="absolute inset-0 pointer-events-none mix-blend-soft-light opacity-30"
    style={`background-image:url(${media.overlayTexture}); background-size: 512px 512px;`}
  ></div>

  <div class="relative px-6 py-14 sm:px-10 sm:py-20">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 rounded-full border border-stone-200/10 bg-black/25 px-3 py-1 text-xs uppercase tracking-[0.24em] text-stone-200/80">
        <span class="h-2 w-2 rounded-full bg-[#c8a27c]"></span>
        {nombre} · Reserva online y WhatsApp
      </div>

      <h1 class="mt-5 text-3xl font-semibold tracking-tight text-zinc-50 sm:text-5xl">
        {title}
      </h1>

      <p class="mt-4 max-w-xl text-sm leading-relaxed text-stone-200/80 sm:text-base">
        {subtitle}
      </p>

      <div class="mt-7 flex flex-col gap-2 sm:flex-row">
        <a
          href="/turnos"
          class="rounded-2xl border border-[#c8a27c]/35 bg-[#c8a27c]/14 px-5 py-4 text-center text-sm font-semibold text-stone-100 transition hover:bg-[#c8a27c]/22"
        >
          Reservar experiencia
        </a>

        <a
          href="/servicios"
          class="rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-center text-sm font-semibold text-zinc-100 transition hover:bg-white/10"
        >
          Ver servicios
        </a>

        <a
          href="/ubicacion"
          class="rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-center text-sm font-semibold text-zinc-100 transition hover:bg-white/10"
        >
          Cómo llegar
        </a>
      </div>
    </div>
  </div>
</section>
