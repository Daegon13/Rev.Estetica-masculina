---
import type { Professional } from "@types/domain";

type Props = {
  barberos: Array<Pick<Professional, "nombre" | "especialidad" | "foto" | "alt">>;
};

const { barberos } = Astro.props as Props;
---

<section class="mt-10 py-4">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h2 class="text-2xl font-semibold text-zinc-50">Equipo profesional</h2>
      <p class="mt-2 max-w-2xl text-sm leading-7 text-zinc-400">
        Perfiles listos para respaldar la propuesta comercial con especialidades claras, imagen cuidada y autoridad técnica.
      </p>
    </div>
    <div class="pill-badge w-fit">Percepción premium</div>
  </div>

  <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {barberos.map((b) => (
      <article class="overflow-hidden rounded-[1.75rem] border border-stone-200/10 bg-gradient-to-b from-white/8 to-white/[0.03] shadow-soft">
        {b.foto ? (
          <img
            src={b.foto}
            alt={b.alt ?? b.nombre}
            class="h-64 w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="h-64 w-full bg-gradient-to-b from-white/5 to-black/20"></div>
        )}

        <div class="p-5 sm:p-6">
          <div class="flex items-start justify-between gap-3">
            <div>
              <div class="text-base font-semibold text-zinc-50">{b.nombre}</div>
              <div class="mt-2 text-sm leading-6 text-zinc-400">{b.especialidad}</div>
            </div>
            <span class="rounded-full border border-white/10 bg-black/20 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-zinc-300">Especialista</span>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
