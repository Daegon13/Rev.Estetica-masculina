---
import type { Professional } from "@types/domain";

type Props = {
  barberos: Array<Pick<Professional, "nombre" | "especialidad" | "foto" | "alt">>;
};

const { barberos } = Astro.props as Props;
---

<section class="mt-10">
  <div class="flex items-end justify-between gap-6">
    <div>
      <h2 class="text-xl font-semibold text-zinc-50">Equipo profesional</h2>
      <p class="mt-2 text-sm text-zinc-400">
        Especialistas en imagen masculina, detalle técnico y atención consistente.
      </p>
    </div>
  </div>

  <div class="mt-6 grid gap-4 md:grid-cols-2">
    {barberos.map((b) => (
      <article class="overflow-hidden rounded-2xl border border-stone-200/10 bg-gradient-to-b from-white/8 to-white/[0.03] shadow-soft">
        {b.foto ? (
          <img
            src={b.foto}
            alt={b.alt ?? b.nombre}
            class="h-56 w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class="h-56 w-full bg-gradient-to-b from-white/5 to-black/20"></div>
        )}

        <div class="p-5">
          <div class="text-base font-semibold text-zinc-50">{b.nombre}</div>
          <div class="mt-1 text-sm text-zinc-400">{b.especialidad}</div>
        </div>
      </article>
    ))}
  </div>
</section>
