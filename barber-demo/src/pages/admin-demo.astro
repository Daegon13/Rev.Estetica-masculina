---
import BaseLayout from "@layouts/BaseLayout.astro";
import MessageTemplatesDemo from "@components/MessageTemplatesDemo.astro";
import { DEMO_TODAY, DEMO_TODAY_LABEL } from "@config/demo";
import {
  demoAppointments,
  demoAutomations,
  demoClients,
  demoDashboardAppointments,
  inactiveClients,
  upcomingBirthdays
} from "@data/demoBusiness";

const title = "Admin Demo — Panel comercial";
const description = "Panel demo para mostrar agenda, clientes y automatizaciones del sistema a dueños de negocios de estética masculina.";
const todayLabel = DEMO_TODAY_LABEL;

const countByStatus = (status: (typeof demoAppointments)[number]["estado"]) =>
  demoAppointments.filter((appointment) => appointment.estado === status).length;

const summaryCards = [
  {
    label: "Turnos cargados hoy",
    value: String(demoAppointments.length),
    trend: `${countByStatus("confirmado")} confirmados · ${countByStatus("pendiente")} pendientes`,
    detail: `${countByStatus("completado")} completados · ${countByStatus("cancelado")} cancelado para recuperar`,
    tone: "from-emerald-400/20 via-emerald-300/8 to-transparent"
  },
  {
    label: "Clientes en la base demo",
    value: String(demoClients.length),
    trend: `${upcomingBirthdays.length} cumpleaños próximos`,
    detail: `${inactiveClients.length} sin visita hace más de 30 días`,
    tone: "from-sky-400/20 via-sky-300/8 to-transparent"
  },
  {
    label: "Automatizaciones listas",
    value: String(demoAutomations.length),
    trend: `${demoAutomations.filter((automation) => automation.estado === "activa").length} activas ahora`,
    detail: `${demoAutomations.reduce((total, automation) => total + automation.proximosEnvios, 0)} envíos proyectados`,
    tone: "from-amber-300/20 via-amber-200/8 to-transparent"
  },
  {
    label: "Oportunidad comercial",
    value: `UYU ${inactiveClients.reduce((total, client) => total + client.ticketPromedio, 0).toLocaleString("es-UY")}`,
    trend: "Win-back + cumpleaños esta semana",
    detail: "El demo conecta agenda, CRM y mensajería con casos reales de venta.",
    tone: "from-fuchsia-400/20 via-fuchsia-300/8 to-transparent"
  }
];

const statusStyles = {
  confirmado: "bg-emerald-400/15 text-emerald-200 border-emerald-300/20",
  pendiente: "bg-amber-400/15 text-amber-100 border-amber-300/20",
  completado: "bg-sky-400/15 text-sky-200 border-sky-300/20",
  cancelado: "bg-rose-400/15 text-rose-200 border-rose-300/20"
} as const;

const statusLabel = {
  confirmado: "Confirmado",
  pendiente: "Pendiente",
  completado: "Completado",
  cancelado: "Cancelado"
} as const;

const reactivationLabel = (lastVisit: string) => {
  const today = new Date(`${DEMO_TODAY}T00:00:00Z`).getTime();
  const visit = new Date(`${lastVisit}T00:00:00Z`).getTime();
  const days = Math.floor((today - visit) / (1000 * 60 * 60 * 24));

  if (days > 30) return `Dormido ${days} días · activar win-back`;
  if (days <= 7) return "Activo reciente · pedir reseña";
  return "Seguimiento liviano · recordar próxima visita";
};

const fmtDate = (date: string, options: Intl.DateTimeFormatOptions) =>
  new Intl.DateTimeFormat("es-UY", { timeZone: "UTC", ...options }).format(new Date(`${date}T00:00:00Z`));
---

<BaseLayout title={title} description={description}>
  <section class="space-y-8">
    <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-gradient-to-br from-white/10 via-white/[0.04] to-white/[0.02] p-6 shadow-soft sm:p-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 rounded-full border border-[#c8a27c]/25 bg-[#c8a27c]/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-[#e8cfb6]">
            Demo comercial
          </div>
          <h1 class="mt-4 text-3xl font-semibold tracking-tight text-zinc-50 sm:text-4xl">
            Panel con datos demo creíbles para mostrar operación, agenda y recurrencia sin depender de datos reales.
          </h1>
          <p class="mt-4 max-w-2xl text-sm leading-6 text-zinc-400 sm:text-base">
            La demo de Rev. Estética Masculina aterriza servicios, profesionales, clientes y automatizaciones en un negocio local de Montevideo para que el lead entienda rápido cómo se vería su día a día usando el sistema.
          </p>
        </div>

        <div class="grid gap-3 rounded-3xl border border-white/10 bg-black/20 p-4 text-sm text-zinc-300 sm:min-w-[320px]">
          <div class="flex items-center justify-between gap-4">
            <span>Ocupación estimada de hoy</span>
            <strong class="text-zinc-50">83%</strong>
          </div>
          <div class="flex items-center justify-between gap-4">
            <span>Próximos cumpleaños</span>
            <strong class="text-zinc-50">{upcomingBirthdays.length}</strong>
          </div>
          <div class="flex items-center justify-between gap-4">
            <span>Clientes a reactivar</span>
            <strong class="text-zinc-50">{inactiveClients.length}</strong>
          </div>
        </div>
      </div>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {summaryCards.map((card) => (
        <article class={`overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br ${card.tone} p-5 shadow-soft`}>
          <div class="text-sm text-zinc-400">{card.label}</div>
          <div class="mt-3 flex items-end justify-between gap-4">
            <strong class="text-3xl font-semibold text-zinc-50 sm:text-4xl">{card.value}</strong>
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-zinc-200">{card.trend}</span>
          </div>
          <p class="mt-4 text-sm text-zinc-300">{card.detail}</p>
        </article>
      ))}
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.35fr_.65fr]">
      <section class="rounded-3xl border border-white/10 bg-white/[0.045] p-5 shadow-soft sm:p-6">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h2 class="text-xl font-semibold text-zinc-50">Agenda del día</h2>
            <p class="mt-1 text-sm text-zinc-400">12 citas demo con estados variados para mostrar seguimiento real de agenda y atención.</p>
          </div>
          <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">{todayLabel}</div>
        </div>

        <div class="mt-5 overflow-hidden rounded-2xl border border-white/10">
          <table class="min-w-full divide-y divide-white/10 text-left text-sm">
            <thead class="bg-white/5 text-zinc-400">
              <tr>
                <th class="px-4 py-3 font-medium">Hora</th>
                <th class="px-4 py-3 font-medium">Cliente</th>
                <th class="px-4 py-3 font-medium">Servicio</th>
                <th class="px-4 py-3 font-medium">Profesional</th>
                <th class="px-4 py-3 font-medium">Estado</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              {demoDashboardAppointments.map((item) => (
                <tr class="bg-transparent transition hover:bg-white/[0.03]">
                  <td class="px-4 py-3 font-medium text-zinc-100">{item.hora}</td>
                  <td class="px-4 py-3 text-zinc-200">{item.cliente?.nombre}</td>
                  <td class="px-4 py-3 text-zinc-300">{item.servicio?.nombre}</td>
                  <td class="px-4 py-3 text-zinc-300">{item.profesional?.nombre}</td>
                  <td class="px-4 py-3">
                    <span class={`inline-flex rounded-full border px-3 py-1 text-xs font-semibold ${statusStyles[item.estado]}`}>
                      {statusLabel[item.estado]}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <aside class="space-y-6">
        <MessageTemplatesDemo />

        <section class="rounded-3xl border border-white/10 bg-gradient-to-br from-[#c8a27c]/14 via-white/[0.03] to-white/[0.02] p-5 shadow-soft sm:p-6">
          <div class="text-sm text-zinc-300">Automatizaciones recomendadas</div>
          <div class="mt-3 space-y-3">
            {demoAutomations.map((automation) => (
              <article class="rounded-2xl border border-white/10 bg-black/20 p-4">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <h3 class="font-semibold text-zinc-50">{automation.nombre}</h3>
                    <p class="mt-1 text-sm text-zinc-400">{automation.objetivo}</p>
                  </div>
                  <span class={`rounded-full border px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] ${automation.estado === "activa" ? "border-emerald-300/20 bg-emerald-400/10 text-emerald-200" : "border-amber-300/20 bg-amber-400/10 text-amber-100"}`}>
                    {automation.estado}
                  </span>
                </div>
                <div class="mt-3 grid gap-2 text-sm text-zinc-300">
                  <div><span class="text-zinc-500">Disparador:</span> {automation.disparador}</div>
                  <div><span class="text-zinc-500">Audiencia:</span> {automation.audiencia}</div>
                  <div><span class="text-zinc-500">Próximos envíos:</span> {automation.proximosEnvios}</div>
                </div>
                <p class="mt-3 text-sm leading-6 text-zinc-300">{automation.impacto}</p>
              </article>
            ))}
          </div>
        </section>
      </aside>
    </div>

    <section class="rounded-3xl border border-white/10 bg-white/[0.045] p-5 shadow-soft sm:p-6">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-xl font-semibold text-zinc-50">Clientes y reactivación</h2>
          <p class="mt-1 text-sm text-zinc-400">18 clientes demo con últimas visitas, cumpleaños y contexto comercial para campañas útiles.</p>
        </div>
        <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">CRM liviano</div>
      </div>

      <div class="mt-5 overflow-hidden rounded-2xl border border-white/10">
        <table class="min-w-full divide-y divide-white/10 text-left text-sm">
          <thead class="bg-white/5 text-zinc-400">
            <tr>
              <th class="px-4 py-3 font-medium">Nombre</th>
              <th class="px-4 py-3 font-medium">Teléfono</th>
              <th class="px-4 py-3 font-medium">Última visita</th>
              <th class="px-4 py-3 font-medium">Cumpleaños</th>
              <th class="px-4 py-3 font-medium">Estado sugerido</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {demoClients.map((client) => (
              <tr class="transition hover:bg-white/[0.03]">
                <td class="px-4 py-3 font-medium text-zinc-100">{client.nombre}</td>
                <td class="px-4 py-3 text-zinc-300">{client.telefono}</td>
                <td class="px-4 py-3 text-zinc-300">{fmtDate(client.ultimaVisita, { day: "2-digit", month: "short", year: "numeric" })}</td>
                <td class="px-4 py-3 text-zinc-300">{fmtDate(client.birthday, { day: "2-digit", month: "short" })}</td>
                <td class="px-4 py-3">
                  <span class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-zinc-200">{reactivationLabel(client.ultimaVisita)}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </section>
</BaseLayout>
