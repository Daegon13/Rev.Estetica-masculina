---
import BaseLayout from "../layouts/BaseLayout.astro";
import barber from "../data/barber.json";
import Section from "@components/Section.astro";
import ServiceCard from "../components/ServiceCard.astro";
import BarbersSection from "../components/BarbersSection.astro";

const title = `Servicios y precios — ${barber.nombre}`;
const description = "Servicios de estética masculina con duración, precio y reserva directa por WhatsApp.";
---

<BaseLayout title={title} description={description}>
  <Section
    title="Servicios"
    subtitle="Opciones claras para resolver corte, barba y mantenimiento con una experiencia premium y comercial."
  >
    <div class="grid gap-4 md:grid-cols-2">
      {barber.servicios.map((s) => (
        <ServiceCard service={s} brand={barber.nombre} whatsapp={barber.whatsapp} />
      ))}
    </div>

    <BarbersSection barberos={barber.barberos} />
  </Section>
</BaseLayout>
