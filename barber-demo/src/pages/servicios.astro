---
import BaseLayout from "../layouts/BaseLayout.astro";
import barber from "../data/barber.json";
import { demoServices } from "../data/services";
import Section from "@components/Section.astro";
import ServicesGrid from "@components/ServicesGrid.astro";
import BarbersSection from "../components/BarbersSection.astro";

const title = `Servicios y precios — ${barber.nombre}`;
const description = "Servicios de estética masculina con duración, precio y reserva directa por WhatsApp.";
---

<BaseLayout title={title} description={description}>
  <Section
    title="Servicios"
    subtitle="Una propuesta de servicios demo enfocada en imagen masculina integral, con datos reutilizables para reserva, agenda y futuras automatizaciones."
  >
    <ServicesGrid servicios={demoServices} />

    <BarbersSection barberos={barber.barberos} />
  </Section>
</BaseLayout>
