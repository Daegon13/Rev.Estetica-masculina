---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import Section from "@components/Section.astro";
import type { BarberData } from "../lib/types";
import BarbersSection from "../components/BarbersSection.astro";
import ServiceCard from "@components/ServiceCard.astro";
import Testimonials from "@components/Testimonials.astro";
import barber from "@data/barber.json";
import { demoServices } from "@data/services";
import { buildWhatsAppLink } from "@lib/whatsapp";

const ctaBusiness = buildWhatsAppLink(
  barber.whatsapp,
  `Hola, quiero esta demo para mi negocio. Quiero ver cómo aplicar el sistema en ${barber.nombre}.`
);
const ctaWhatsApp = buildWhatsAppLink(
  barber.whatsapp,
  `Hola, quiero hablar por WhatsApp para implementar esta demo en mi negocio.`
);
const data = barber as unknown as BarberData;

const featured =
  demoServices.filter((s) => s.popular).slice(0, 4).length > 0
    ? demoServices.filter((s) => s.popular).slice(0, 4)
    : demoServices.slice(0, 4);

const ownerBenefits = [
  {
    title: "Agenda online que llena huecos",
    description:
      "El cliente puede reservar sin esperar respuesta, y eso te ayuda a ocupar mejor los horarios que antes se perdían entre mensajes y llamadas.",
    icon: "calendar"
  },
  {
    title: "Confirmaciones que ordenan el día",
    description:
      "Antes de abrir el local, ya sabés quién viene, quién confirmó y qué turnos necesitan seguimiento para que la jornada corra prolija.",
    icon: "check"
  },
  {
    title: "Reseñas que traen confianza",
    description:
      "Después de una buena atención, el sistema invita a dejar opinión y te ayuda a mostrar movimiento real, buen servicio y clientes conformes.",
    icon: "star"
  },
  {
    title: "Clientes que vuelven sin perseguirlos",
    description:
      "Si alguien se enfrió, sale un mensaje en el momento justo para volver a mover la silla y recuperar ventas que parecían perdidas.",
    icon: "refresh"
  }
] as const;

const title = `${data.nombre} — Estética masculina premium`;
const description = `Cuidado masculino integral, reserva online y experiencia profesional en ${data.ciudad}.`;
---
<BaseLayout title={title} description={description}>
  <Hero />

  <Section
    title="Servicios destacados"
    subtitle="Servicios demo de estética masculina integral con foco en imagen, cuidado facial y mantenimiento premium."
  >
    <div class="grid gap-4 md:grid-cols-2">
      {featured.map((s) => (
        <ServiceCard service={s} brand={barber.nombre} whatsapp={barber.whatsapp} />
      ))}
    </div>
  </Section>

  <Section
    id="como-funciona"
    title="Cómo funciona el sistema de agenda"
    subtitle="Una experiencia premium para reservar online, confirmar por WhatsApp y sostener una relación más inteligente con cada cliente."
  >
    <div class="grid gap-4 md:grid-cols-3">
      {[
        { t: "Turnos online", d: "El cliente elige servicio y horario en una interfaz simple, rápida y alineada con una marca de imagen masculina contemporánea." },
        { t: "Confirmación por WhatsApp", d: "Cada reserva baja la fricción operativa con mensajes claros para confirmar asistencia y mantener el contacto." },
        { t: "Recordatorio y fidelización", d: "Los recordatorios automáticos ayudan a reducir ausencias y dejan una base lista para impulsar recurrencia." }
      ].map((x) => (
        <div class="rounded-2xl border border-stone-200/10 bg-gradient-to-b from-white/8 to-white/[0.03] p-5">
          <div class="font-semibold text-zinc-100">{x.t}</div>
          <div class="mt-2 text-sm text-zinc-400">{x.d}</div>
        </div>
      ))}
    </div>
  </Section>

  <Section
    id="negocio"
    title="Más que turnos: un sistema para hacer crecer el negocio"
    subtitle="Pensado para que el dueño del local venda mejor, ordene la agenda y tenga más clientes volviendo sin depender todo el tiempo del celular."
  >
    <div class="grid gap-4 lg:grid-cols-[1.1fr_.9fr]">
      <div class="rounded-[2rem] border border-[#c8a27c]/20 bg-[linear-gradient(180deg,rgba(200,162,124,0.16),rgba(255,255,255,0.03))] p-6 shadow-soft sm:p-7">
        <div class="inline-flex rounded-full border border-[#c8a27c]/30 bg-[#c8a27c]/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#e7c7a3]">
          Demo comercial
        </div>
        <h3 class="mt-4 max-w-xl text-2xl font-semibold leading-tight text-zinc-50 sm:text-3xl">
          Mostrale al dueño cómo pasa de apagar incendios a tener una agenda que vende todos los días.
        </h3>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-zinc-300 sm:text-base">
          Esta sección está pensada para cerrar el demo: no se trata solo de tomar reservas, sino de darle al local una forma más prolija de llenar horarios, confirmar asistencia, generar confianza y recuperar clientes dormidos.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-200">Menos huecos en la agenda</div>
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-200">Más orden sin sumar personal</div>
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-200">Más recurrencia y recomendación</div>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
        {ownerBenefits.map((item) => (
          <article class="rounded-[1.75rem] border border-stone-200/10 bg-gradient-to-b from-white/8 to-white/[0.03] p-5 shadow-soft">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-[#c8a27c]/25 bg-[#c8a27c]/10 text-[#f2d3b0]">
              {item.icon === "calendar" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3.5" y="5" width="17" height="15.5" rx="2.5"></rect>
                  <path d="M7.5 3.5v3"></path>
                  <path d="M16.5 3.5v3"></path>
                  <path d="M3.5 9.5h17"></path>
                  <path d="M8 13h3"></path>
                  <path d="M8 16.5h7"></path>
                </svg>
              )}
              {item.icon === "check" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 21c4.97 0 9-4.03 9-9s-4.03-9-9-9-9 4.03-9 9 4.03 9 9 9Z"></path>
                  <path d="m8.5 12.3 2.3 2.4 4.8-5.1"></path>
                </svg>
              )}
              {item.icon === "star" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m12 3.8 2.4 4.86 5.36.78-3.88 3.78.92 5.33L12 16.9l-4.8 2.52.92-5.33-3.88-3.78 5.36-.78L12 3.8Z"></path>
                </svg>
              )}
              {item.icon === "refresh" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6v5h-5"></path>
                  <path d="M4 18v-5h5"></path>
                  <path d="M6.9 9A7 7 0 0 1 18 7.2L20 11"></path>
                  <path d="M17.1 15A7 7 0 0 1 6 16.8L4 13"></path>
                </svg>
              )}
            </div>
            <h3 class="mt-4 text-lg font-semibold text-zinc-50">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </Section>

  <BarbersSection barberos={barber.barberos} />

  <Section
    title="Testimonios"
    subtitle="Percepción de servicio, reserva online y resultado final desde la mirada de los clientes."
  >
    <Testimonials items={barber.testimonios} />
  </Section>

  <section class="mt-6 overflow-hidden rounded-[2rem] border border-[#c8a27c]/20 bg-[radial-gradient(circle_at_top_left,rgba(200,162,124,0.22),transparent_38%),linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03))] p-6 shadow-soft sm:p-8 lg:p-10">
    <div class="grid gap-8 lg:grid-cols-[1.2fr_.8fr] lg:items-center">
      <div>
        <div class="inline-flex rounded-full border border-[#c8a27c]/30 bg-[#c8a27c]/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#e7c7a3]">
          Cierre comercial listo para presentar
        </div>
        <h2 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight text-zinc-50 sm:text-4xl">
          Menos ausencias. Más orden. Más clientes que vuelven.
        </h2>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-zinc-300 sm:text-base">
          Mostrale al dueño que puede resolver agenda online, recordatorios, confirmaciones y seguimiento comercial desde un mismo sistema premium, en vez de pagar varias herramientas separadas y perder tiempo coordinando todo a mano.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-100">Una sola demo para vender reserva, orden y recurrencia</div>
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-100">Menos apps sueltas, menos costo operativo</div>
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-100">Presentación clara para leads premium desde mañana</div>
        </div>
      </div>

      <div class="rounded-[1.75rem] border border-white/10 bg-black/20 p-5 sm:p-6">
        <div class="text-xs uppercase tracking-[0.22em] text-[#e7c7a3]">Próximo paso</div>
        <div class="mt-3 text-2xl font-semibold text-zinc-50">Convertí el demo en una propuesta concreta para barberías y centros de estética masculina.</div>
        <p class="mt-3 text-sm leading-6 text-zinc-400">
          Ideal para mostrar ahorro, profesionalismo y una operación más predecible sin sacrificar la percepción premium de la marca.
        </p>
        <div class="mt-6 flex flex-col gap-3">
          <a href={ctaBusiness} target="_blank" rel="noreferrer" class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-[#c8a27c]/35 bg-[#c8a27c]/18 px-5 py-4 text-sm font-semibold text-stone-100 transition hover:bg-[#c8a27c]/28">
            Quiero esta demo para mi negocio
          </a>
          <a href={ctaWhatsApp} target="_blank" rel="noreferrer" class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-sm font-semibold text-zinc-100 transition hover:bg-white/10">
            Hablar por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="text-2xl font-semibold text-zinc-50">Ubicación y horarios</h2>
        <p class="mt-2 max-w-2xl text-sm text-zinc-400">Datos configurables para deploy: dirección, WhatsApp comercial y disponibilidad semanal listos para actualizar sin tocar la estructura.</p>
      </div>
      <a href="/ubicacion" class="text-sm font-semibold text-stone-200 transition hover:text-stone-100">Ver detalle completo</a>
    </div>

    <div class="mt-6 grid gap-4 lg:grid-cols-[1.2fr_.8fr]">
      <div class="overflow-hidden rounded-2xl border border-stone-200/10 bg-white/5 shadow-soft">
        <img
          src={barber.media.location}
          alt="Fachada del estudio"
          class="h-[260px] w-full object-cover md:h-[360px]"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="rounded-2xl border border-stone-200/10 bg-gradient-to-b from-white/8 to-white/[0.03] p-6 shadow-soft">
        <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Dirección</div>
        <div class="mt-2 text-lg font-semibold text-zinc-50">{barber.direccion}</div>
        <div class="mt-1 text-sm text-zinc-400">{barber.ciudad}</div>

        <div class="mt-6 text-xs uppercase tracking-[0.2em] text-zinc-500">Horarios</div>
        <div class="mt-2 text-sm text-zinc-200">{barber.horarios.semana}</div>
        <div class="mt-1 text-sm text-zinc-200">{barber.horarios.sabado}</div>
        <div class="mt-3 text-xs text-zinc-500">{barber.horarios.nota}</div>
      </div>
    </div>
  </section>
</BaseLayout>
