---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import Section from "@components/Section.astro";
import type { BarberData } from "../lib/types";
import BarbersSection from "../components/BarbersSection.astro";
import ServicesGrid from "@components/ServicesGrid.astro";
import Testimonials from "@components/Testimonials.astro";
import barber from "@data/barber.json";
import { demoServices } from "@data/services";
import { buildWhatsAppLink } from "@lib/whatsapp";

const ctaBusiness = buildWhatsAppLink(
  barber.whatsapp,
  `Hola, quiero reservar una experiencia en ${barber.nombre}. ¿Me comparten la disponibilidad?`
);
const ctaWhatsApp = buildWhatsAppLink(
  barber.whatsapp,
  `Hola, quiero asesoramiento sobre servicios y turnos en ${barber.nombre}.`
);
const data = barber as unknown as BarberData;


const ownerBenefits = [
  {
    title: "Agenda online",
    description:
      "Tus clientes reservan solos, vos ganás orden y el negocio deja de depender de responder mensajes a mano para llenar la agenda.",
    icon: "calendar"
  },
  {
    title: "Confirmaciones y recordatorios",
    description:
      "El sistema confirma asistencia, recuerda cada turno y baja ausencias para que el día arranque más prolijo y rentable.",
    icon: "check"
  },
  {
    title: "Pedido de reseñas",
    description:
      "Después de cada visita, podés activar pedidos automáticos de opinión para sumar prueba social y convertir buen servicio en más consultas.",
    icon: "star"
  },
  {
    title: "Reactivación de clientes",
    description:
      "Si un cliente desaparece, el sistema lo vuelve a contactar en el momento justo para recuperar ventas sin perseguir uno por uno.",
    icon: "refresh"
  }
] as const;

const title = `${data.nombre} — Estética masculina premium`;
const description = `Cuidado masculino integral, reserva online y experiencia profesional en ${data.ciudad}.`;
---
<BaseLayout title={title} description={description}>
  <Hero />

  <Section
    title="Servicios de estética masculina integral"
    subtitle="Una grilla demo con servicios pensados para corte, barba y cuidado facial desde una propuesta premium, sobria y reutilizable para el flujo de turnos."
  >
    <ServicesGrid servicios={demoServices} />
  </Section>

  <Section
    id="como-funciona"
    title="Cómo funciona el sistema de agenda"
    subtitle="Una experiencia simple para que reservar se sienta rápido, prolijo y alineado con una marca de estética masculina contemporánea."
  >
    <div class="grid gap-4 md:grid-cols-3">
      {[
        { t: "Turnos online", d: "El cliente elige servicio y horario en una interfaz simple, rápida y alineada con una marca de imagen masculina contemporánea." },
        { t: "Confirmación por WhatsApp", d: "Cada reserva baja la fricción operativa con mensajes claros para confirmar asistencia y mantener el contacto." },
        { t: "Recordatorio y fidelización", d: "Los recordatorios automáticos ayudan a reducir ausencias y dejan una base lista para impulsar recurrencia." }
      ].map((x) => (
        <div class="rounded-2xl border border-stone-200/10 bg-gradient-to-b from-white/8 to-white/[0.03] p-5">
          <div class="font-semibold text-zinc-100">{x.t}</div>
          <div class="mt-2 text-sm text-zinc-400">{x.d}</div>
        </div>
      ))}
    </div>
  </Section>

  <Section
    id="negocio"
    title="Más que agenda: una herramienta para hacer crecer el negocio"
    subtitle="No es solo una landing prolija: es una propuesta comercial que muestra cómo el sistema ordena la operación, reduce ausencias y ayuda a facturar más en un negocio local."
  >
    <div class="grid gap-5 lg:grid-cols-[1.05fr_.95fr]">
      <div class="rounded-[2rem] border border-[#c8a27c]/20 bg-[linear-gradient(180deg,rgba(200,162,124,0.18),rgba(255,255,255,0.03))] p-6 shadow-soft sm:p-7">
        <div class="inline-flex rounded-full border border-[#c8a27c]/30 bg-[#c8a27c]/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#e7c7a3]">
          Pensado para dueños de negocio local
        </div>
        <h3 class="mt-4 max-w-xl text-2xl font-semibold leading-tight text-zinc-50 sm:text-3xl">
          La home vende una solución completa: agenda, seguimiento y acciones para que cada cliente valga más.
        </h3>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-zinc-300 sm:text-base">
          En vez de mostrar solo un formulario bonito, esta sección deja claro qué gana el negocio: menos tiempo operativo, más asistencia, mejor reputación y clientes que regresan con más frecuencia.
        </p>
        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-4 text-sm text-zinc-200">
            <div class="text-2xl font-semibold text-zinc-50">+ orden</div>
            <div class="mt-1 text-xs uppercase tracking-[0.18em] text-zinc-400">menos ida y vuelta</div>
          </div>
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-4 text-sm text-zinc-200">
            <div class="text-2xl font-semibold text-zinc-50">- ausencias</div>
            <div class="mt-1 text-xs uppercase tracking-[0.18em] text-zinc-400">confirmación automática</div>
          </div>
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-4 text-sm text-zinc-200">
            <div class="text-2xl font-semibold text-zinc-50">+ recurrencia</div>
            <div class="mt-1 text-xs uppercase tracking-[0.18em] text-zinc-400">clientes que vuelven</div>
          </div>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {ownerBenefits.map((item) => (
          <article class="rounded-[1.75rem] border border-stone-200/10 bg-gradient-to-b from-white/8 to-white/[0.03] p-5 shadow-soft">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-[#c8a27c]/25 bg-[#c8a27c]/10 text-[#f2d3b0]">
              {item.icon === "calendar" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3.5" y="5" width="17" height="15.5" rx="2.5"></rect>
                  <path d="M7.5 3.5v3"></path>
                  <path d="M16.5 3.5v3"></path>
                  <path d="M3.5 9.5h17"></path>
                  <path d="M8 13h3"></path>
                  <path d="M8 16.5h7"></path>
                </svg>
              )}
              {item.icon === "check" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 21c4.97 0 9-4.03 9-9s-4.03-9-9-9-9 4.03-9 9 4.03 9 9 9Z"></path>
                  <path d="m8.5 12.3 2.3 2.4 4.8-5.1"></path>
                </svg>
              )}
              {item.icon === "star" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m12 3.8 2.4 4.86 5.36.78-3.88 3.78.92 5.33L12 16.9l-4.8 2.52.92-5.33-3.88-3.78 5.36-.78L12 3.8Z"></path>
                </svg>
              )}
              {item.icon === "refresh" && (
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6v5h-5"></path>
                  <path d="M4 18v-5h5"></path>
                  <path d="M6.9 9A7 7 0 0 1 18 7.2L20 11"></path>
                  <path d="M17.1 15A7 7 0 0 1 6 16.8L4 13"></path>
                </svg>
              )}
            </div>
            <h3 class="mt-4 text-lg font-semibold text-zinc-50">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </Section>

  <BarbersSection barberos={barber.barberos} />

  <Section
    title="Testimonios"
    subtitle="Opiniones reales que refuerzan la propuesta de valor y la calidad percibida del servicio."
  >
    <Testimonials items={barber.testimonios} />
  </Section>

  <section class="mt-8 overflow-hidden rounded-[2rem] border border-[#c8a27c]/20 bg-[radial-gradient(circle_at_top_left,rgba(200,162,124,0.22),transparent_38%),linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03))] p-6 shadow-soft sm:p-8 lg:p-10">
    <div class="grid gap-8 lg:grid-cols-[1.2fr_.8fr] lg:items-center">
      <div>
        <div class="inline-flex rounded-full border border-[#c8a27c]/30 bg-[#c8a27c]/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-[#e7c7a3]">
          Cierre comercial listo para presentar
        </div>
        <h2 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight text-zinc-50 sm:text-4xl">
          Menos ausencias. Más orden. Más clientes que vuelven.
        </h2>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-zinc-300 sm:text-base">
          Reservá tu próximo servicio con una experiencia cuidada de punta a punta: agenda simple, atención puntual y contacto directo para resolver cualquier detalle antes de venir.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-100">Reserva online en pocos pasos</div>
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-100">Atención profesional y personalizada</div>
          <div class="rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-sm text-zinc-100">Seguimiento directo por WhatsApp</div>
        </div>
      </div>

      <div class="rounded-[1.75rem] border border-white/10 bg-black/20 p-5 sm:p-6">
        <div class="text-xs uppercase tracking-[0.22em] text-[#e7c7a3]">Próximo paso</div>
        <div class="mt-3 text-2xl font-semibold text-zinc-50">Coordiná tu próxima visita y elevá tu imagen con atención profesional.</div>
        <p class="mt-3 text-sm leading-6 text-zinc-400">
          Elegí el servicio que necesitás, reservá tu horario y resolvé cualquier consulta previa directamente con el equipo.
        </p>
        <div class="mt-6 flex flex-col gap-3">
          <a href={ctaBusiness} target="_blank" rel="noreferrer" class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-[#c8a27c]/35 bg-[#c8a27c]/18 px-5 py-4 text-sm font-semibold text-stone-100 transition hover:bg-[#c8a27c]/28">
            Reservar por WhatsApp
          </a>
          <a href={ctaWhatsApp} target="_blank" rel="noreferrer" class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-sm font-semibold text-zinc-100 transition hover:bg-white/10">
            Hablar por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="text-2xl font-semibold text-zinc-50">Ubicación y horarios</h2>
        <p class="mt-2 max-w-2xl text-sm text-zinc-400">Encontranos fácilmente, consultá los horarios de atención y coordiná tu próxima visita con el estudio.</p>
      </div>
      <a href="/ubicacion" class="text-sm font-semibold text-stone-200 transition hover:text-stone-100">Ver detalle completo</a>
    </div>

    <div class="mt-6 grid gap-4 lg:grid-cols-[1.2fr_.8fr]">
      <div class="overflow-hidden rounded-2xl border border-stone-200/10 bg-white/5 shadow-soft">
        <img
          src={barber.media.location}
          alt="Fachada de Revolución Estética Masculina"
          class="h-[260px] w-full object-cover md:h-[360px]"
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="rounded-2xl border border-stone-200/10 bg-gradient-to-b from-white/8 to-white/[0.03] p-6 shadow-soft">
        <div class="text-xs uppercase tracking-[0.2em] text-zinc-500">Dirección</div>
        <div class="mt-2 text-lg font-semibold text-zinc-50">{barber.direccion}</div>
        <div class="mt-1 text-sm text-zinc-400">{barber.ciudad}</div>

        <div class="mt-6 text-xs uppercase tracking-[0.2em] text-zinc-500">Horarios</div>
        <div class="mt-2 text-sm text-zinc-200">{barber.horarios.semana}</div>
        <div class="mt-1 text-sm text-zinc-200">{barber.horarios.sabado}</div>
        <div class="mt-3 text-xs text-zinc-500">{barber.horarios.nota}</div>
      </div>
    </div>
  </section>
</BaseLayout>
